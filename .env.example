# =============================================================
# 生成AIポータル 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、値を設定すること
# .env.local は .gitignore に含まれており、gitには含まれない
# =============================================================

# ---------------------------------------------------------------
# JWT設定
# HS256署名用シークレットキー（32文字以上の任意の文字列）
# 例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-here

# ---------------------------------------------------------------
# AES-256暗号化設定
# Dify APIキーの暗号化に使用するキー（32バイト = 64文字の16進数）
# 例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------
AES_SECRET_KEY=your-aes-256-secret-key-64-hex-chars

# ---------------------------------------------------------------
# SQLiteデータベース設定
# DBファイルのパス（プロジェクトルートからの相対パス、またはフルパス）
# ---------------------------------------------------------------
DATABASE_URL=./data/portal.db

# ---------------------------------------------------------------
# 管理者初期ユーザー設定（db:seedコマンドで使用）
# 初回セットアップ時に、change-me-immediatelyを別の文字列に書き換えること
# 初回セットアップ後は削除または変更すること
# ---------------------------------------------------------------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-immediately

# ---------------------------------------------------------------
# アプリケーション設定
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=紫竹山ハイスクール 生成AIポータル
NODE_ENV=development